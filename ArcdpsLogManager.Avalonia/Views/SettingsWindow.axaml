<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GW2Scratch.ArcdpsLogManager.Avalonia.ViewModels"
        x:Class="GW2Scratch.ArcdpsLogManager.Avalonia.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Icon="avares://GW2Scratch.ArcdpsLogManager.Avalonia/Assets/Images/program_icon.ico"
        Title="Settings">

    <DockPanel Margin="16">
        <Button DockPanel.Dock="Bottom" Content="Close" HorizontalAlignment="Right"
                MinWidth="90" Margin="0,12,0,0" Click="OnCloseClick"
                IsDefault="True" IsCancel="True" />

        <ScrollViewer>
            <StackPanel Spacing="14">
                <StackPanel Spacing="6">
                    <TextBlock Text="Appearance" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Theme" VerticalAlignment="Center" Width="120" />
                        <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Settings.Theme}" MinWidth="160" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Log directories" FontWeight="SemiBold" />
                    <TextBlock Text="Folders scanned for arcdps logs." Opacity="0.6" FontSize="12" />
                    <ListBox ItemsSource="{Binding LogDirectories}" Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1" Content="Remove"
                                            Command="{Binding $parent[ListBox].((vm:SettingsWindowViewModel)DataContext).RemoveDirectoryCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Add directory…" HorizontalAlignment="Left" Click="OnAddDirectoryClick" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Log list" FontWeight="SemiBold" />
                    <CheckBox Content="Show failure health percentages in the log list"
                              IsChecked="{Binding Settings.ShowFailurePercentagesInLogList}" />
                    <CheckBox Content="Show guild tags in the log detail panel"
                              IsChecked="{Binding Settings.ShowGuildTagsInLogDetail}" />
                    <CheckBox Content="Show the filter sidebar"
                              IsChecked="{Binding Settings.ShowFilterSidebar}" />
                    <CheckBox Content="Show debug data"
                              IsChecked="{Binding Settings.ShowDebugData}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Minimum log duration (seconds)" VerticalAlignment="Center" Width="220" />
                        <TextBox Text="{Binding MinimumLogDurationText}" Width="90" Watermark="none" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Guild Wars 2 API" FontWeight="SemiBold" />
                    <CheckBox Content="Use the GW2 API (guild names, map names)"
                              IsChecked="{Binding Settings.UseGW2Api}" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="dps.report" FontWeight="SemiBold" />
                    <TextBlock Text="If enabled, newly discovered logs will be automatically queued for an upload if they are less than 1 day old."
                               Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                    <CheckBox Content="Automatically upload logs"
                              IsChecked="{Binding Settings.DpsReportAutoUpload}" />
                    <CheckBox Content="Only upload successful encounters"
                              IsChecked="{Binding Settings.DpsReportAutoUploadApplyFilters}"
                              IsEnabled="{Binding Settings.DpsReportAutoUpload}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="User token" VerticalAlignment="Center" Width="120" />
                        <TextBox Text="{Binding Settings.DpsReportUserToken}" Width="280" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Updates" FontWeight="SemiBold" />
                    <CheckBox Content="Check for program updates on startup"
                              IsChecked="{Binding Settings.CheckForUpdates}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
