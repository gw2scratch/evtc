<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GW2Scratch.ArcdpsLogManager.Avalonia.ViewModels"
             x:Class="GW2Scratch.ArcdpsLogManager.Avalonia.Views.MultipleLogPanelView"
             x:DataType="vm:MultipleLogPanelViewModel">

    <Panel IsVisible="{Binding HasSelection}" Margin="12">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
            <TextBlock Grid.Row="0" Text="{Binding CountText}" FontSize="16" FontWeight="Bold" />

            <!-- Statistics -->
            <HeaderedContentControl Grid.Row="1" Header="Statistics" Theme="{StaticResource GroupBoxTheme}"
                                     Margin="0,8,0,0">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Success logs:" Margin="0,0,8,2" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SuccessCountText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Failure logs:" Margin="0,0,8,2" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FailureCountText}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Sum of log times:" Margin="0,0,8,2"
                               ToolTip.Tip="Total fight-clock time: each selected log's own encounter duration, added up." />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SumOfDurationsText}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Session length:" Margin="0,0,8,2"
                               ToolTip.Tip="Wall-clock time from the earliest log's start to the latest log's end, including time spent between pulls." />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SessionLengthText}" />
                </Grid>
            </HeaderedContentControl>

            <!-- Debug data (mirrors the Eto panel's "Debug data" group, shown only when the
                 debug-data setting is enabled). -->
            <HeaderedContentControl Grid.Row="2" Header="Debug data" Theme="{StaticResource GroupBoxTheme}"
                                     Margin="0,8,0,0" IsVisible="{Binding ShowDebugData}">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="Time spent processing:" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding ParseTimeText}" />
                    </Grid>
                    <Button Content="Reprocess all" Command="{Binding ReprocessAllCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </HeaderedContentControl>

            <!-- Tags common to every selected log. -->
            <HeaderedContentControl Grid.Row="3" Header="Tags" Theme="{StaticResource GroupBoxTheme}"
                                     Margin="0,8,0,0" IsVisible="{Binding ShowTags}">
                <StackPanel Spacing="4">
                    <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding HasTags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                        CornerRadius="4" Padding="6,2" Margin="0,0,4,4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        <Button Content="✕" Padding="2,0" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding $parent[ItemsControl].((vm:MultipleLogPanelViewModel)DataContext).RemoveTagCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding NewTag}" Watermark="Add tag to all selected…"
                                 Margin="0,0,4,0" />
                        <Button Grid.Column="1" Content="Add" Command="{Binding AddTagCommand}" />
                    </Grid>
                </StackPanel>
            </HeaderedContentControl>

            <!-- dps.report aggregate status; fills the remaining vertical space so the uploaded-link
                 list can grow into it. -->
            <HeaderedContentControl Grid.Row="4" Header="Upload to dps.report (Elite Insights)"
                                     Theme="{StaticResource GroupBoxTheme}" Margin="0,8,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Not uploaded:" Margin="0,0,8,2" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NotUploadedText}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Uploading:" Margin="0,0,8,2" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UploadingText}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Uploaded:" Margin="0,0,8,2" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UploadedText}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Upload failed:" Margin="0,0,8,2"
                                   IsVisible="{Binding HasUploadFailures}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UploadFailedText}"
                                   IsVisible="{Binding HasUploadFailures}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="dps.report error:" Margin="0,0,8,2"
                                   IsVisible="{Binding HasProcessingFailures}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ProcessingFailedText}"
                                   IsVisible="{Binding HasProcessingFailures}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="{Binding UploadButtonText}"
                                Command="{Binding UploadMissingCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Margin="0,0,4,0" />
                        <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelUploadsCommand}" />
                    </Grid>

                    <ProgressBar Grid.Row="2" Minimum="0" Maximum="{Binding UploadProgressMax}"
                                 Value="{Binding UploadProgressValue}" Height="16" Margin="0,8,0,0" />

                    <TextBox Grid.Row="3" Text="{Binding UploadedUrlsText}"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalAlignment="Stretch" Margin="0,8,0,0" />

                    <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Name="CopyLinksButton" IsEnabled="{Binding HasUploadedLogs}"
                                ToolTip.Tip="Copy links" Margin="0,0,4,0">
                            <Image Source="{Binding CopyIcon}" Width="16" Height="16" />
                        </Button>
                        <Button Grid.Column="1" Name="OpenLinksButton" Content="Open uploaded logs in a browser"
                                IsEnabled="{Binding HasUploadedLogs}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                    </Grid>
                </Grid>
            </HeaderedContentControl>
        </Grid>
    </Panel>
</UserControl>
