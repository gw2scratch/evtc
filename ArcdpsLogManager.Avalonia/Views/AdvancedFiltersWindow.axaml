<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:GW2Scratch.ArcdpsLogManager.Avalonia.ViewModels"
        xmlns:models="using:GW2Scratch.ArcdpsLogManager.Avalonia.Models"
        xmlns:views="using:GW2Scratch.ArcdpsLogManager.Avalonia.Views"
        xmlns:players="using:GW2Scratch.ArcdpsLogManager.Logs.Filters.Players"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
        x:Class="GW2Scratch.ArcdpsLogManager.Avalonia.Views.AdvancedFiltersWindow"
        x:DataType="vm:AdvancedFiltersWindowViewModel"
        Width="900" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Icon="avares://GW2Scratch.ArcdpsLogManager.Avalonia/Assets/Images/program_icon.ico"
        Title="Advanced filters - arcdps Log Manager">

    <Window.Resources>
        <!-- Shared row template for one profession/specialization composition count filter. -->
        <DataTemplate x:Key="CompositionRowTemplate" x:DataType="models:CompositionFilterRow">
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1">
                <Image Source="{Binding Icon}" Width="20" Height="20" ToolTip.Tip="{Binding Label}" />
                <ComboBox Width="56" Padding="4,2" ItemsSource="{Binding FilterTypeOptions}"
                          SelectedItem="{Binding Filter.FilterType}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={x:Static views:FilterEnumTextConverter.Instance}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <NumericUpDown Width="90" Minimum="0" Maximum="100" Increment="1" FormatString="0"
                                Value="{Binding Filter.PlayerCount}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="Close" HorizontalAlignment="Right" MinWidth="90"
                Margin="0,10,0,0" Click="OnCloseClick" IsDefault="True" IsCancel="True" />

        <TabControl>
            <TabItem Header="Squad composition">
                <DockPanel Margin="6">
                    <Button DockPanel.Dock="Top" Content="Reset composition" HorizontalAlignment="Left"
                            Margin="0,0,0,8" Command="{Binding ResetCompositionCommand}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Core professions" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding CoreProfessionRows}"
                                              ItemTemplate="{StaticResource CompositionRowTemplate}" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Heart of Thorns" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding HeartOfThornsRows}"
                                              ItemTemplate="{StaticResource CompositionRowTemplate}" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Path of Fire" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding PathOfFireRows}"
                                              ItemTemplate="{StaticResource CompositionRowTemplate}" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="End of Dragons" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding EndOfDragonsRows}"
                                              ItemTemplate="{StaticResource CompositionRowTemplate}" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Visions of Eternity" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding VisionsOfEternityRows}"
                                              ItemTemplate="{StaticResource CompositionRowTemplate}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="Mistlock Instabilities">
                <StackPanel Margin="6" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Show logs with" VerticalAlignment="Center" />
                        <ComboBox Width="140" ItemsSource="{Binding InstabilityTypeOptions}"
                                  SelectedItem="{Binding Filters.InstabilityFilters.Type}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static views:FilterEnumTextConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="of the checked instabilities" VerticalAlignment="Center" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding InstabilityRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:InstabilityFilterRow">
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="4" Width="230">
                                        <Image Source="{Binding Icon}" Width="20" Height="20" />
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock TextWrapping="Wrap" Opacity="0.7" MaxWidth="500" HorizontalAlignment="Left"
                               Text="Tip: you can enable the Mistlock Instabilities column in the log list by right-clicking the log list header and checking the related option." />
                </StackPanel>
            </TabItem>

            <TabItem Header="Players">
                <StackPanel Margin="6" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Require" VerticalAlignment="Center" />
                        <ComboBox Width="140" ItemsSource="{Binding PlayerTypeOptions}"
                                  SelectedItem="{Binding Filters.PlayerFilters.Type}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static views:FilterEnumTextConverter.Instance}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="of these players in the log" VerticalAlignment="Center" />
                    </StackPanel>

                    <ListBox Height="220" ItemsSource="{Binding Filters.PlayerFilters.RequiredPlayers}"
                             SelectedItem="{Binding SelectedRequiredPlayer}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="players:RequiredPlayerFilter">
                                <TextBlock Text="{Binding AccountName, Converter={x:Static views:AccountNameDisplayConverter.Instance}}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add player…" Click="OnAddPlayerClick" />
                        <Button Content="Remove selected" Command="{Binding RemoveSelectedPlayerCommand}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Processing status">
                <StackPanel Margin="6" Spacing="6">
                    <CheckBox Content="Unprocessed" IsChecked="{Binding Filters.ShowParseUnparsedLogs}" />
                    <CheckBox Content="Processing" IsChecked="{Binding Filters.ShowParseParsingLogs}" />
                    <CheckBox Content="Processed" IsChecked="{Binding Filters.ShowParseParsedLogs}" />
                    <CheckBox Content="Failed" IsChecked="{Binding Filters.ShowParseFailedLogs}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="dps.report uploads">
                <StackPanel Margin="6" Spacing="6">
                    <CheckBox Content="Not uploaded" IsChecked="{Binding Filters.ShowDpsReportUnuploadedLogs}" />
                    <CheckBox Content="Uploaded" IsChecked="{Binding Filters.ShowDpsReportUploadedLogs}" />
                    <CheckBox Content="Queued" IsChecked="{Binding Filters.ShowDpsReportQueuedLogs}" />
                    <CheckBox Content="Upload failed (dps.report unreachable)"
                              IsChecked="{Binding Filters.ShowDpsReportUploadErrorLogs}" />
                    <CheckBox Content="Processing failed (Elite Insights on dps.report failed)"
                              IsChecked="{Binding Filters.ShowDpsReportProcessingErrorLogs}" />
                    <TextBlock TextWrapping="Wrap" Opacity="0.7" MaxWidth="500" Margin="0,6,0,0"
                               Text="Note: Currently, some logs in the processing failed state may have URLs when dps.report reports an error, but also provides an URL to the uploaded report." />
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
