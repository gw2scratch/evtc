<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GW2Scratch.ArcdpsLogManager.Avalonia.ViewModels"
        x:Class="GW2Scratch.ArcdpsLogManager.Avalonia.Views.AboutWindow"
        x:DataType="vm:AboutWindowViewModel"
        Width="330" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Icon="avares://GW2Scratch.ArcdpsLogManager.Avalonia/Assets/Images/program_icon.ico"
        Title="About - arcdps Log Manager">

    <!-- Avalonia counterpart of the Eto Commands/About.cs AboutDialog: logo, name, description,
         developer credit, links, and the license summary text (collapsed by default). -->
    <StackPanel Margin="20" Spacing="14">
        <Grid ColumnDefinitions="Auto,*">
            <Image Grid.Column="0" Source="avares://GW2Scratch.ArcdpsLogManager.Avalonia/Assets/Images/program_icon.ico"
                   Width="48" Height="48" VerticalAlignment="Top" />
            <StackPanel Grid.Column="1" Spacing="2" Margin="14,0,0,0">
                <TextBlock Text="arcdps Log Manager" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="{Binding VersionText}" Opacity="0.7" />
                <TextBlock Text="A manager for EVTC logs generated by arcdps, a Guild Wars 2 addon."
                           TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <TextBlock Text="Developed by Sejsel" HorizontalAlignment="Center" />

        <StackPanel Spacing="4" HorizontalAlignment="Center">
            <Button Classes="link" Content="https://gw2scratch.com/" HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center" Click="OnOpenWebsiteClick" />
            <Button Classes="link" Content="https://discord.gg/rNXRS6ZkYe" HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center" Click="OnOpenDiscordClick" />
            <Button Classes="link" Content="https://github.com/gw2scratch/evtc" HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center" Click="OnOpenGitHubClick" />
            <Button Classes="link" Content="https://ko-fi.com/sejsel ❤️" HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center" Click="OnOpenDonateClick" />
        </StackPanel>

        <Button Content="{Binding CheckUpdatesButtonText}" HorizontalAlignment="Center"
                IsEnabled="{Binding !IsCheckingForUpdates}" Click="OnCheckUpdatesClick" />

        <Expander Header="MIT License" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <TextBox Text="{Binding LicenseText}" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="Wrap" Height="180" FontFamily="Consolas,monospace" FontSize="11"
                     Margin="0,8,0,0" />
        </Expander>

        <Button Content="Close" HorizontalAlignment="Right" MinWidth="90" Click="OnCloseClick"
                IsDefault="True" IsCancel="True" />
    </StackPanel>
</Window>
